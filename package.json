{
  "name": "emdash",
  "version": "0.4.45",
  "description": "A cross-platform Electron app that orchestrates multiple coding agents in parallel",
  "main": "dist/main/main/entry.js",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "d": "pnpm install && pnpm run dev",
    "dev": "concurrently \"pnpm run dev:main\" \"pnpm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json && node scripts/copy-main-assets.cjs && electron dist/main/main/entry.js --dev",
    "dev:renderer": "vite",
    "test": "vitest run",
    "build": "pnpm run build:main && pnpm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json && node scripts/copy-main-assets.cjs",
    "build:renderer": "vite build",
    "package": "pnpm run build && electron-builder",
    "package:mac": "pnpm run build && electron-builder --mac",
    "package:linux": "pnpm run build && electron-builder --linux --publish never",
    "package:win": "pnpm run build && electron-builder --win --publish never",
    "postinstall": "node scripts/postinstall.cjs",
    "rebuild": "electron-rebuild -f -v 30.5.1 --only=sqlite3,node-pty,keytar",
    "clean": "node scripts/clean.cjs",
    "reset": "pnpm run clean && pnpm install",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "docs": "cd docs && pnpm run dev",
    "docs:build": "cd docs && pnpm run build",
    "prepare": "husky"
  },
  "keywords": [
    "electron",
    "coding-agents",
    "git",
    "claude",
    "openai"
  ],
  "author": {
    "name": "Emdash Contributors",
    "email": "support@emdash.sh"
  },
  "engines": {
    "node": ">=20.0.0 <23.0.0",
    "pnpm": ">=10.28.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@iconify-json/lucide": "^1.2.101",
    "@iconify-json/simple-icons": "^1.2.76",
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "drizzle-kit": "^0.24.2",
    "electron": "^30.5.1",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.27.0",
    "eslint": "^8.55.0",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.3.0",
    "postcss": "^8.4.32",
    "prettier": "3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "unplugin-icons": "^23.0.1",
    "vite": "8.0.0-beta.18",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.168.10",
    "@types/ssh2": "^1.15.5",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dompurify": "^3.3.3",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.32.1",
    "electron-updater": "^6.3.9",
    "fix-path": "^4.0.0",
    "human-id": "^4.1.2",
    "ignore": "^5.3.1",
    "jsonc-parser": "^3.3.1",
    "keytar": "^7.9.0",
    "marked": "^17.0.6",
    "minimatch": "^10.2.3",
    "monaco-editor": "^0.55.1",
    "nbranch": "^0.1.0",
    "node-pty": "1.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-resizable-panels": "^3.0.6",
    "smol-toml": "^1.6.0",
    "sqlite3": "^5.1.7",
    "ssh2": "^1.17.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "build": {
    "appId": "com.emdash",
    "productName": "Emdash",
    "directories": {
      "output": "release"
    },
    "artifactName": "emdash-${arch}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "generalaction",
        "repo": "emdash",
        "releaseType": "release"
      }
    ],
    "generateUpdatesFilesForAllChannels": true,
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "drizzle/**/*"
    ],
    "asarUnpack": [
      "node_modules/sqlite3/**",
      "node_modules/node-pty/**",
      "node_modules/keytar/**",
      "**/*.node"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "LSEnvironment": {
          "LANG": "en_US.UTF-8",
          "LC_CTYPE": "en_US.UTF-8"
        }
      },
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "src/assets/images/emdash/emdash.icns",
      "notarize": false
    },
    "dmg": {
      "icon": "src/assets/images/emdash/emdash.icns"
    },
    "linux": {
      "category": "Development",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "src/assets/images/emdash/icon-light.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        }
      ],
      "azureSignOptions": {
        "publisherName": "General Action, Inc.",
        "endpoint": "https://eus.codesigning.azure.net/",
        "certificateProfileName": "emdash-public",
        "codeSigningAccountName": "emdash"
      }
    },
    "msi": {
      "oneClick": false,
      "perMachine": false
    },
    "nsis": {
      "differentialPackage": true,
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "npmRebuild": false
  },
  "pnpm": {
    "overrides": {
      "app-builder-lib>minimatch": "10.1.2",
      "minimatch@3": "3.1.4",
      "minimatch@5": "5.1.8",
      "minimatch@9": "9.0.7",
      "minimatch@10": "10.2.3"
    },
    "onlyBuiltDependencies": [
      "sqlite3",
      "node-pty",
      "keytar",
      "electron"
    ],
    "ignoredBuiltDependencies": [
      "core-js",
      "cpu-features",
      "esbuild",
      "protobufjs",
      "ssh2"
    ],
    "patchedDependencies": {
      "ssh2@1.17.0": "patches/ssh2@1.17.0.patch"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,jsx,json,css}": [
      "prettier --write"
    ]
  }
}
